class Solution {
    public int maxSubarraySum(int[] arr, int k) {
    int n = arr.length;
    int sum = 0;
    int maxSum = 0;

    // First window
    for (int i = 0; i < k; i++)
        sum += arr[i];

    maxSum = sum;

    // Slide
    for (int i = k; i < n; i++) {
        sum = sum + arr[i] - arr[i - k];
        maxSum = Math.max(maxSum, sum);
    }

    return maxSum;
}
}
